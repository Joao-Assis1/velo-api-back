generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  phone           String?
  cpf             String?
  profilePicture  String?
  password        String?
  ladvUploaded    Boolean   @default(false)
  ladv_document_url String?
  ladv_validation_date DateTime?
  termsAcceptedAt DateTime?
  lessons         Lesson[]
  payments        Payment[]
  paymentMethods  PaymentMethod[]
}

model Instructor {
  id              String         @id @default(uuid())
  email           String         @unique
  name            String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  phone           String?
  cpf             String?
  profilePicture  String?
  password        String?
  bio             String?
  instructorType  String?
  location        String?
  pricePerClass   Float?
  rating          Float          @default(0)
  reviewsCount    Int            @default(0)
  termsAcceptedAt DateTime?
  cnhNumber       String?
  cnhCategory     String?
  cnhExpiry       String?
  cnhEar          Boolean        @default(false)
  certidaoNegativa String?
  availabilities  Availability[]
  lessons         Lesson[]
  vehicles        Vehicle[]
  busySlots       BusySlot[]
}

model Vehicle {
  id           String     @id @default(uuid())
  plate        String     @unique
  model        String
  instructorId String
  transmission String?
  vehiclePhoto String?
  year         String?
  lessons      Lesson[]
  instructor   Instructor @relation(fields: [instructorId], references: [id])
}

model Availability {
  id           String     @id @default(uuid())
  startTime    String
  endTime      String
  instructorId String
  dayOfWeek    Int
  isEnabled    Boolean    @default(true)
  instructor   Instructor @relation(fields: [instructorId], references: [id])
}

model BusySlot {
  id            String     @id @default(uuid())
  instructorId  String
  date          DateTime
  startTime     String     // "14:00"
  endTime       String     // "16:00"
  reason        String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  instructor    Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([instructorId, date, startTime])
  @@index([instructorId])
  @@index([instructorId, date])
}

model Lesson {
  id                    String     @id @default(uuid())
  studentId             String
  instructorId          String
  vehicleId             String?
  startTime             String
  endTime               String
  status                String     @default("upcoming")
  checkInTime           DateTime?
  checkOutTime          DateTime?
  date                  DateTime
  durationMinutes       Int?
  instructorFeedback    String?
  price                 Float?
  studentFeedbackRating Int?
  studentFeedbackText   String?
  instructor            Instructor @relation(fields: [instructorId], references: [id])
  student               Student    @relation(fields: [studentId], references: [id])
  vehicle               Vehicle?   @relation(fields: [vehicleId], references: [id])
  payment               Payment?

  @@unique([instructorId, date, startTime], name: "unique_booking_slot")
}

model PaymentMethod {
  id              String    @id @default(uuid())
  studentId       String
  token           String    // Stripe/Token mock
  last4           String
  cardholderName  String
  expiryMonth     String
  expiryYear      String
  isDefault       Boolean   @default(false)
  isDeleted       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  student         Student   @relation(fields: [studentId], references: [id])
  payments        Payment[]

  @@unique([studentId, token])
}

model Payment {
  id              String         @id @default(uuid())
  amount          Float
  status          String         @default("PENDING")
  studentId       String
  lessonId        String?        @unique
  paymentMethodId String?
  lesson          Lesson?        @relation(fields: [lessonId], references: [id])
  student         Student        @relation(fields: [studentId], references: [id])
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
}

