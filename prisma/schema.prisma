generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  phone           String?
  cpf             String
  profilePicture  String?
  password        String?
  ladvUploaded    Boolean   @default(false)
  ladv_document_url String?
  ladv_validation_date DateTime?
  termsAcceptedAt DateTime?
  birthDate       String?
  motherName      String?
  ufDomicile      String?
  intendedCategory String?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  // === Journey Foundation ===
  journeyStage             String    @default("REGISTERED")
  theoryCourseStartedAt    DateTime?
  readyForPracticalExamAt  DateTime?

  // === LADV extras ===
  ladvNumber               String?
  ladvIssuedAt             DateTime?
  ladvValidUntil           DateTime?
  ladvOcrConfidence        Float?
  ladvOcrStatus            String?

  // === Stripe (preparação) ===
  stripeCustomerId         String?   @unique

  // Relations
  lessons               Lesson[]
  payments              Payment[]
  paymentMethods        PaymentMethod[]
  checklist             StudentChecklist?
  simulados             StudentSimuladoHistory[]
  renachProcess         RenachProcess?
  medicalExam           MedicalExam?
  psychologicalExam     PsychologicalExam?
  officialTheoryExam    OfficialTheoryExam?
}

model Question {
  id        String   @id @default(uuid())
  text      String
  category  String   // Legislacao, Direcao Defensiva, Primeiros Socorros, Meio Ambiente, Mecanica
  options   String[] // Array of strings
  correct   Int      // Index of correct option
  createdAt DateTime @default(now())
}

model StudentSimuladoHistory {
  id          String   @id @default(uuid())
  studentId   String
  score       Int      // 0-30
  passed      Boolean
  startedAt   DateTime
  submittedAt DateTime
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model StudentChecklist {
  id              String   @id @default(uuid())
  studentId       String   @unique
  medico          Boolean  @default(false)
  psicotecnico    Boolean  @default(false)
  teorico         Boolean  @default(false)
  pratico         Boolean  @default(false)
  updatedAt       DateTime @updatedAt
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Instructor {
  id              String         @id @default(uuid())
  email           String         @unique
  name            String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  phone           String?
  cpf             String?
  profilePicture  String?
  password        String?
  bio             String?
  instructorType  String?
  location        String?
  pricePerClass   Float?
  rating          Float          @default(0)
  reviewsCount    Int            @default(0)
  termsAcceptedAt DateTime?
  cnhNumber       String?
  cnhCategory     String?
  cnhExpiry       String?
  cnhEar          Boolean        @default(false)
  certidaoNegativa String?
  birthDate       String?
  educationLevel  String?
  renachNumber    String?
  isActive        Boolean        @default(true)
  passwordResetToken   String?
  passwordResetExpires DateTime?
  pixKey          String?
  bankCode        String?
  bankAgency      String?
  bankAccount     String?
  // === Credenciamento DETRAN (Resolução 1.020/2025) ===
  detranCredentialNumber String?
  detranCredentialUf     String?
  credentialValidUntil   DateTime?
  credentialStatus       String    @default("PENDING")

  // === Stripe Connect (preparação) ===
  stripeAccountId        String?   @unique
  stripeAccountStatus    String    @default("PENDING")
  stripePayoutsEnabled   Boolean   @default(false)

  availabilities  Availability[]
  lessons         Lesson[]
  vehicles        Vehicle[]
  busySlots       BusySlot[]
}

model Vehicle {
  id           String     @id @default(uuid())
  plate        String     @unique
  model        String
  instructorId String
  transmission String?
  vehiclePhoto String?
  year         String?
  lessons      Lesson[]
  instructor   Instructor @relation(fields: [instructorId], references: [id])
}

model Availability {
  id           String     @id @default(uuid())
  startTime    String
  endTime      String
  instructorId String
  dayOfWeek    Int
  isEnabled    Boolean    @default(true)
  instructor   Instructor @relation(fields: [instructorId], references: [id])
}

model BusySlot {
  id            String     @id @default(uuid())
  instructorId  String
  date          DateTime
  startTime     String     // "14:00"
  endTime       String     // "16:00"
  reason        String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  instructor    Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([instructorId, date, startTime])
  @@index([instructorId])
  @@index([instructorId, date])
}

model Lesson {
  id                    String            @id @default(uuid())
  studentId             String
  instructorId          String
  vehicleId             String?
  startTime             String
  endTime               String
  status                String            @default("pending_acceptance")
  createdAt             DateTime          @default(now())
  checkInTime           DateTime?
  checkOutTime          DateTime?
  date                  DateTime
  durationMinutes       Int?
  instructorFeedback    String?
  price                 Float?
  studentFeedbackRating Int?
  studentFeedbackText   String?
  integrityHash         String?           // Hash de integridade (Escudo)
  
  // Rastreamento de Biometria em 3 Tempos
  biometryStartStatus   String?           // PENDING, SUCCESS, FAILED
  biometryStartAt       DateTime?
  biometryMidStatus     String?
  biometryMidAt         DateTime?
  biometryEndStatus     String?
  biometryEndAt         DateTime?

  // Financeiro e Disputas
  paymentReleased       Boolean           @default(false)
  disputeOpened         Boolean           @default(false)
  disputeReason         String?

  instructor            Instructor        @relation(fields: [instructorId], references: [id])
  student               Student           @relation(fields: [studentId], references: [id])
  vehicle               Vehicle?          @relation(fields: [vehicleId], references: [id])
  payment               Payment?
  telemetry             LessonTelemetry[] // Relacionamento com Telemetria
  events                LessonEvent[]     // Eventos de orientação (Navegador)

  @@unique([instructorId, date, startTime], name: "unique_booking_slot")
}

model LessonTelemetry {
  id        String   @id @default(uuid())
  lessonId  String
  timestamp DateTime @default(now())
  lat       Float
  lng       Float
  velocity  Float    @default(0)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([timestamp])
}

model LessonEvent {
  id        String   @id @default(uuid())
  lessonId  String
  type      String   // SPEED_LIMIT, HARSH_BRAKING, ROUTE_DEVIATION, ENGINE_ON, ENGINE_OFF
  message   String
  lat       Float
  lng       Float
  timestamp DateTime @default(now())
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([type])
}

model PaymentMethod {
  id                    String    @id @default(uuid())
  studentId             String
  stripePaymentMethodId String    @unique
  brand                 String
  last4                 String
  cardholderName        String
  expiryMonth           String
  expiryYear            String
  isDefault             Boolean   @default(false)
  isDeleted             Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  student               Student   @relation(fields: [studentId], references: [id])
  payments              Payment[]

  @@index([studentId, isDeleted])
}

model Payment {
  id                    String         @id @default(uuid())
  amount                Float
  status                String         @default("PENDING")
  studentId             String
  lessonId              String?        @unique
  paymentMethodId       String?
  stripePaymentIntentId String?        @unique
  stripeTransferId      String?        @unique
  stripeRefundId        String?
  failureReason         String?
  platformFeeAmount     Float?
  instructorAmount      Float?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  lesson                Lesson?        @relation(fields: [lessonId], references: [id])
  student               Student        @relation(fields: [studentId], references: [id])
  paymentMethod         PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  @@index([status])
  @@index([stripePaymentIntentId])
}

// ============================================================================
// Journey Foundation — tabelas novas (CONTRAN 1.020/2025)
// ============================================================================

model RenachProcess {
  id              String    @id @default(uuid())
  studentId       String    @unique
  renachNumber    String?
  ufDetran        String
  biometryDoneAt  DateTime?
  status          String    @default("PENDING")
  proofUrl        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Clinic {
  id          String    @id @default(uuid())
  name        String
  type        String
  city        String
  uf          String
  address     String
  phone       String?
  price       Float
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  medicalExams       MedicalExam[]
  psychologicalExams PsychologicalExam[]

  @@index([uf, city, type])
}

model MedicalExam {
  id              String    @id @default(uuid())
  studentId       String    @unique
  clinicId        String?
  protocolCode    String    @unique
  scheduledAt     DateTime?
  performedAt     DateTime?
  result          String?
  restrictions    String?
  validUntil      DateTime?
  laudoUrl        String?
  status          String    @default("PENDING")
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  clinic          Clinic?   @relation(fields: [clinicId], references: [id])

  @@index([status])
}

model PsychologicalExam {
  id              String    @id @default(uuid())
  studentId       String    @unique
  clinicId        String?
  protocolCode    String    @unique
  scheduledAt     DateTime?
  performedAt     DateTime?
  result          String?
  restrictions    String?
  validUntil      DateTime?
  laudoUrl        String?
  status          String    @default("PENDING")
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  clinic          Clinic?   @relation(fields: [clinicId], references: [id])

  @@index([status])
}

model OfficialTheoryExam {
  id          String    @id @default(uuid())
  studentId   String    @unique
  takenAt     DateTime
  score       Int?
  passed      Boolean
  proofUrl    String?
  createdAt   DateTime  @default(now())
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([passed])
}

