generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id             String    @id @default(uuid())
  email          String    @unique
  name           String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  phone          String?
  cpf            String?
  profilePicture String?
  ladvUploaded   Boolean   @default(false)
  lessons        Lesson[]
  payments       Payment[]
}

model Instructor {
  id             String         @id @default(uuid())
  email          String         @unique
  name           String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  phone          String?
  cpf            String?
  profilePicture String?
  bio            String?
  instructorType String?
  location       String?
  pricePerClass  Float?
  rating         Float          @default(0)
  reviewsCount   Int            @default(0)
  availabilities Availability[]
  lessons        Lesson[]
  vehicles       Vehicle[]
}

model Vehicle {
  id           String     @id @default(uuid())
  plate        String     @unique
  model        String
  instructorId String
  transmission String?
  vehiclePhoto String?
  year         String?
  lessons      Lesson[]
  instructor   Instructor @relation(fields: [instructorId], references: [id])
}

model Availability {
  id           String     @id @default(uuid())
  startTime    String
  endTime      String
  instructorId String
  dayOfWeek    Int
  isEnabled    Boolean    @default(true)
  instructor   Instructor @relation(fields: [instructorId], references: [id])
}

model Lesson {
  id                    String     @id @default(uuid())
  studentId             String
  instructorId          String
  vehicleId             String?
  startTime             String
  endTime               String
  status                String     @default("upcoming")
  checkInTime           DateTime?
  checkOutTime          DateTime?
  date                  DateTime
  durationMinutes       Int?
  instructorFeedback    String?
  price                 Float?
  studentFeedbackRating Int?
  studentFeedbackText   String?
  instructor            Instructor @relation(fields: [instructorId], references: [id])
  student               Student    @relation(fields: [studentId], references: [id])
  vehicle               Vehicle?   @relation(fields: [vehicleId], references: [id])
  payment               Payment?
}

model Payment {
  id        String  @id @default(uuid())
  amount    Float
  status    String  @default("PENDING")
  studentId String
  lessonId  String? @unique
  lesson    Lesson? @relation(fields: [lessonId], references: [id])
  student   Student @relation(fields: [studentId], references: [id])
}
