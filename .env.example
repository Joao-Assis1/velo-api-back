# Database
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth — gerar com: npm run jwt-key
JWT_SECRET=change_me_at_least_32_chars_long

# Admin API (obrigatório, mínimo 16 caracteres)
ADMIN_API_KEY=change_me_16chars_minimum

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECT_REFRESH_URL=
STRIPE_CONNECT_RETURN_URL=

# Server
PORT=3001
NODE_ENV=development

# Document validation: mock (default) | serpro
DOCUMENT_VALIDATION_PROVIDER=mock

# Test mode — bypass de OCR da LADV via header X-Test-Mode: true
# NUNCA setar como true em produção
# ENABLE_TEST_MODE=false

# External APIs (defaults embutidos)
# VIA_CEP_BASE_URL=https://viacep.com.br/ws
# BRASIL_API_BASE_URL=https://brasilapi.com.br/api

# CORS (opcional; aceita origem única, lista separada por vírgula ou regex)
# CORS_ORIGIN=http://localhost:3000

# Escrow retry (opcional)
# ESCROW_MAX_RETRY_ATTEMPTS=3
# ESCROW_RETRY_CRON=0 * * * *

# Stripe platform fee (opcional)
# PLATFORM_FEE_PERCENT=15
